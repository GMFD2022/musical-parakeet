# Minimal .gitignore to allow assets to be tracked
# Only exclude essential build artifacts and system files

# Build outputs
/build/
.gradle/

# Local configuration
local.properties

# IDE
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Log files
*.log

// Load and parse the accounts
const accounts = JSON.parse(accountsJson);
const accountMap = new Map(accounts.map(a => [a.address, a]));

// Lookup an account
function getAccountName(address: string) {
  return accountMap.get(address)?.name || "Unknown Account";
}